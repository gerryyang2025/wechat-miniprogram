.consult-scroll {
  min-height: 100vh;
  padding: calc(108rpx + env(safe-area-inset-top)) 28rpx 0;
  box-sizing: border-box;
}

.consult-nav {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding-bottom: 28rpx;
}

.consult-back {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  font-size: 44rpx;
  line-height: 72rpx;
  text-align: center;
}

.consult-nav-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.consult-nav-title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #ffffff;
}

.consult-nav-subtitle {
  font-size: 24rpx;
  color: rgba(241, 244, 255, 0.82);
}

.consult-hero,
.consult-section {
  margin-top: 24rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.consult-hero-tag {
  align-self: flex-start;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(83, 112, 255, 0.1);
  color: #5b6dfc;
  font-size: 22rpx;
  font-weight: 700;
}

.consult-hero-title,
.consult-section-title {
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 800;
  color: #222946;
}

.consult-hero-desc,
.consult-helper {
  font-size: 24rpx;
  line-height: 1.72;
  color: #7f89ab;
}

.question-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.question-chip {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(239, 243, 255, 0.96);
  color: #57627f;
  font-size: 22rpx;
  font-weight: 600;
}

.consult-textarea-shell {
  padding: 22rpx;
  border-radius: 28rpx;
  background: rgba(247, 249, 255, 0.96);
  border: 1rpx solid rgba(224, 230, 250, 0.94);
}

.consult-textarea {
  width: 100%;
  min-height: 280rpx;
  font-size: 26rpx;
  line-height: 1.72;
  color: #596486;
}

.consult-bottom-spacer {
  height: calc(148rpx + env(safe-area-inset-bottom));
}

.consult-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(247, 249, 255, 0.92);
  backdrop-filter: blur(12px);
  box-shadow: 0 -18rpx 40rpx rgba(69, 82, 147, 0.08);
}

.consult-footer-inner {
  display: flex;
}

.consult-primary {
  width: 100%;
  height: 88rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #4f80ff 0%, #7258ff 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
