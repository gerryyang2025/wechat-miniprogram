.content-ops-scroll {
  min-height: 100vh;
  padding: calc(108rpx + env(safe-area-inset-top)) 28rpx 0;
  box-sizing: border-box;
}

.content-ops-nav {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding-bottom: 28rpx;
}

.content-ops-back {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  font-size: 44rpx;
  line-height: 72rpx;
  text-align: center;
}

.content-ops-nav-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.content-ops-nav-title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #ffffff;
}

.content-ops-nav-subtitle {
  font-size: 24rpx;
  color: rgba(241, 244, 255, 0.82);
}

.content-ops-hero,
.content-ops-section {
  margin-top: 24rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.content-ops-badge {
  align-self: flex-start;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(83, 112, 255, 0.1);
  color: #5b6dfc;
  font-size: 22rpx;
  font-weight: 700;
}

.content-ops-title,
.content-ops-section-title {
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 800;
  color: #222946;
}

.content-ops-desc,
.content-ops-section-note,
.banner-config-note,
.notice-content {
  font-size: 24rpx;
  line-height: 1.72;
  color: #7f89ab;
}

.content-ops-section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
}

.banner-config-list,
.slot-list,
.notice-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.banner-config-item,
.slot-item,
.notice-item {
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(247, 249, 255, 0.9);
  border: 1rpx solid rgba(224, 230, 250, 0.94);
}

.banner-config-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.banner-config-preview {
  flex-shrink: 0;
  width: 148rpx;
  height: 94rpx;
  border-radius: 20rpx;
  background: linear-gradient(145deg, #6f57ff 0%, #4f90ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-config-mark {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.banner-config-copy,
.slot-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.banner-config-title,
.slot-label,
.notice-title {
  font-size: 28rpx;
  line-height: 1.45;
  color: #202742;
  font-weight: 700;
}

.banner-config-current,
.slot-content {
  font-size: 24rpx;
  line-height: 1.65;
  color: #5f6a8e;
}

.banner-config-action,
.slot-action,
.notice-action {
  align-self: flex-start;
  flex-shrink: 0;
  min-width: 132rpx;
  height: 60rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(92, 108, 255, 0.08);
  color: #5a6efa;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.slot-item,
.notice-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.notice-item {
  flex-direction: column;
  align-items: flex-start;
}

.content-ops-bottom-spacer {
  height: calc(48rpx + env(safe-area-inset-bottom));
}
