.home-page {
  min-height: 100vh;
}

.home-scroll {
  min-height: 100vh;
}

.home-content-safe-bottom {
  padding-bottom: calc(96rpx + env(safe-area-inset-bottom));
}

.home-bottom-spacer {
  height: calc(120rpx + env(safe-area-inset-bottom));
}

.hero-panel {
  padding: calc(108rpx + env(safe-area-inset-top)) 32rpx 26rpx;
}

.hero-top {
  display: block;
}

.brand-copy {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hero-badge {
  align-self: flex-start;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: rgba(255, 255, 255, 0.92);
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

.hero-title {
  font-size: 64rpx;
  line-height: 1.05;
  font-weight: 800;
  color: #ffffff;
}

.hero-subtitle {
  width: 92%;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(239, 243, 255, 0.84);
}

.search-bar {
  margin-top: 28rpx;
  height: 88rpx;
  padding: 0 28rpx 0 32rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 16rpx 36rpx rgba(31, 34, 82, 0.12);
}

.search-placeholder {
  color: #9ca4c4;
  font-size: 28rpx;
}

.search-icon {
  font-size: 40rpx;
  color: #454d76;
}

.main-content {
  margin-top: 6rpx;
  padding: 0 28rpx 0;
}

.banner-block {
  position: relative;
  overflow: hidden;
  padding: 0;
}

.banner-swiper {
  width: 100%;
  height: 320rpx;
}

.banner-slide {
  position: relative;
  width: 100%;
  height: 320rpx;
}

.banner-image {
  width: 100%;
  height: 320rpx;
  display: block;
}

.banner-shadow {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 100rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.22) 100%);
}

.banner-indicators {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 0 18rpx;
}

.indicator {
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(147, 157, 198, 0.3);
}

.indicator.is-active {
  width: 38rpx;
  background: linear-gradient(135deg, #5e82ff 0%, #745cff 100%);
}

.owned-section {
  padding: 28rpx;
  background: linear-gradient(180deg, rgba(235, 244, 255, 0.98) 0%, rgba(248, 251, 255, 0.98) 100%);
}

.section-head,
.recommend-header,
.feature-stack-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title-wrap {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.section-title-text {
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #1e2543;
}

.section-subtitle {
  font-size: 24rpx;
  color: #8690b6;
}

.owned-list {
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.owned-card {
  width: 100%;
  min-height: 156rpx;
  border-radius: 28rpx;
  padding: 22rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  box-sizing: border-box;
}

.owned-card--purple {
  background: linear-gradient(145deg, #f0efff 0%, #ffffff 100%);
}

.owned-card--blue {
  background: linear-gradient(145deg, #e8f4ff 0%, #ffffff 100%);
}

.owned-card--cyan {
  background: linear-gradient(145deg, #e6f8ff 0%, #ffffff 100%);
}

.owned-card--indigo {
  background: linear-gradient(145deg, #eceaff 0%, #ffffff 100%);
}

.owned-mark {
  flex-shrink: 0;
  width: 92rpx;
  height: 92rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(84, 110, 255, 0.18);
}

.owned-mark--purple {
  background: linear-gradient(145deg, #6f57ff 0%, #4f90ff 100%);
}

.owned-mark--cyan {
  background: linear-gradient(145deg, #1f8dff 0%, #4ec8ff 100%);
}

.owned-mark--indigo {
  background: linear-gradient(145deg, #4a53d6 0%, #7f76ff 100%);
}

.owned-mark-text {
  font-size: 28rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.owned-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.owned-badge {
  align-self: flex-start;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(108, 124, 255, 0.1);
  color: #6278f4;
  font-size: 20rpx;
  font-weight: 600;
}

.owned-title {
  font-size: 28rpx;
  line-height: 1.4;
  color: #232847;
  font-weight: 700;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.owned-meta {
  font-size: 24rpx;
  color: #6278f4;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.owned-summary {
  font-size: 22rpx;
  line-height: 1.6;
  color: #7f89ab;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.owned-action {
  flex-shrink: 0;
  min-width: 104rpx;
  text-align: right;
  font-size: 24rpx;
  font-weight: 700;
  color: #556dfb;
}

.recommend-section {
  margin-top: 28rpx;
}

.course-card {
  margin-top: 22rpx;
  padding: 22rpx;
  display: flex;
  gap: 22rpx;
}

.course-cover {
  flex-shrink: 0;
  width: 236rpx;
  height: 196rpx;
  border-radius: 24rpx;
  padding: 20rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: #ffffff;
  overflow: hidden;
}

.cover-purple {
  background: linear-gradient(145deg, #6f57ff 0%, #4f90ff 100%);
}

.cover-blue {
  background: linear-gradient(145deg, #2b80ff 0%, #56c7ff 100%);
}

.cover-indigo {
  background: linear-gradient(145deg, #4250d8 0%, #7f73ff 100%);
}

.course-cover-tag {
  align-self: flex-start;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 20rpx;
  font-weight: 600;
}

.course-cover-title {
  font-size: 26rpx;
  line-height: 1.5;
  font-weight: 600;
}

.course-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 12rpx;
}

.course-title {
  font-size: 32rpx;
  line-height: 1.45;
  color: #202642;
  font-weight: 700;
}

.course-author,
.course-meta {
  font-size: 24rpx;
  line-height: 1.6;
  color: #7d86a9;
}

.course-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.course-price {
  color: #f06c3e;
  font-size: 34rpx;
  font-weight: 800;
}

.course-action {
  flex-shrink: 0;
  height: 60rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4f80ff 0%, #7258ff 100%);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature-stack {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.feature-stack-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.feature-card {
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.feature-card--camp {
  background: linear-gradient(145deg, rgba(232, 241, 255, 0.98) 0%, rgba(255, 255, 255, 0.96) 100%);
}

.feature-card--live {
  background: linear-gradient(145deg, rgba(245, 239, 255, 0.98) 0%, rgba(255, 255, 255, 0.96) 100%);
}

.feature-card--member {
  background: linear-gradient(145deg, rgba(255, 244, 234, 0.98) 0%, rgba(255, 255, 255, 0.96) 100%);
}

.feature-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.feature-eyebrow {
  font-size: 22rpx;
  color: #6b78af;
  font-weight: 600;
}

.feature-title {
  font-size: 32rpx;
  line-height: 1.35;
  color: #222846;
  font-weight: 700;
}

.feature-desc {
  font-size: 24rpx;
  line-height: 1.65;
  color: #8690b2;
}
