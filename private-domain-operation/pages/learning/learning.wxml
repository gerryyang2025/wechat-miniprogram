<view class="page-shell">
  <scroll-view scroll-y class="learning-scroll content-safe-bottom">
    <view class="learning-head">
      <text class="learning-title">学习</text>
      <text class="learning-subtitle">继续查看已购课程、训练营与直播回放。</text>
    </view>

    <view class="metrics-row">
      <view wx:for="{{metrics}}" wx:key="label" class="metric-card card-surface">
        <text class="metric-value">{{item.value}}</text>
        <text class="metric-label">{{item.label}}</text>
      </view>
    </view>

    <view class="learning-search" bindtap="onSearchTap">
      <text class="learning-search-text">搜索已购课程</text>
      <text class="learning-search-icon">⌕</text>
    </view>

    <view class="learning-live-entry card-surface" bindtap="onOpenLiveCenter">
      <view class="learning-live-copy">
        <text class="learning-live-title">直播中心</text>
        <text class="learning-live-desc">查看即将开始、直播中与回放中的直播内容。</text>
      </view>
      <text class="learning-live-action">查看全部</text>
    </view>

    <view class="learning-list">
      <view wx:for="{{learningList}}" wx:key="id" class="learning-card card-surface" data-item-id="{{item.id}}" bindtap="onItemTap">
        <view class="learning-cover learning-cover--{{item.theme}}">
          <text class="learning-type">{{item.type}}</text>
        </view>
        <view class="learning-body">
          <text class="learning-item-title">{{item.title}}</text>
          <text class="learning-progress">{{item.progress}}</text>
          <text class="learning-last">{{item.last}}</text>
          <view class="learning-action" data-item-id="{{item.id}}" catchtap="onContinueTap">{{item.actionLabel || '继续学习'}}</view>
        </view>
      </view>
    </view>

    <view class="learning-bottom-spacer"></view>
  </scroll-view>

  <bottom-nav current="learning"></bottom-nav>
</view>
