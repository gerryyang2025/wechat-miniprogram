.live-edit-scroll {
  min-height: 100vh;
  padding: calc(108rpx + env(safe-area-inset-top)) 28rpx 0;
  box-sizing: border-box;
}

.live-edit-nav {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding-bottom: 28rpx;
}

.live-edit-back {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  font-size: 44rpx;
  line-height: 72rpx;
  text-align: center;
  flex-shrink: 0;
}

.live-edit-nav-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.live-edit-nav-title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #ffffff;
}

.live-edit-nav-subtitle {
  font-size: 24rpx;
  line-height: 1.45;
  color: rgba(241, 244, 255, 0.82);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.live-edit-loading,
.live-edit-section {
  margin-top: 24rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.live-edit-loading {
  min-height: 180rpx;
  align-items: center;
  justify-content: center;
}

.live-edit-muted {
  font-size: 26rpx;
  line-height: 1.5;
  color: #7f89ab;
}

.live-edit-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.live-edit-section-title {
  flex: 1;
  min-width: 0;
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 800;
  color: #222946;
}

.live-edit-id {
  flex-shrink: 0;
  max-width: 220rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: #8c96b8;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.live-edit-label {
  font-size: 24rpx;
  line-height: 1.5;
  color: #7f89ab;
}

.live-edit-field {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

.live-edit-input,
.live-edit-textarea {
  width: 100%;
  border-radius: 20rpx;
  background: rgba(247, 249, 255, 0.96);
  border: 1rpx solid rgba(224, 230, 250, 0.96);
  color: #202742;
  font-size: 26rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.live-edit-input {
  height: 76rpx;
  padding: 0 22rpx;
}

.live-edit-input--url {
  font-size: 24rpx;
}

.live-edit-textarea {
  height: 156rpx;
  min-height: 156rpx;
  padding: 18rpx 22rpx;
}

.live-edit-switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.live-edit-chip-row,
.live-edit-ref-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.live-edit-chip,
.live-edit-ref {
  min-width: 132rpx;
  min-height: 60rpx;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(239, 243, 255, 0.96);
  color: #7380a6;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.live-edit-chip--active,
.live-edit-ref--active {
  background: linear-gradient(135deg, #4f80ff 0%, #7258ff 100%);
  color: #ffffff;
}

.live-edit-bottom-spacer {
  height: calc(148rpx + env(safe-area-inset-bottom));
}

.live-edit-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(247, 249, 255, 0.92);
  backdrop-filter: blur(12px);
  box-shadow: 0 -18rpx 40rpx rgba(69, 82, 147, 0.08);
}

.live-edit-save {
  width: 100%;
  height: 88rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #4f80ff 0%, #7258ff 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.live-edit-save--disabled {
  opacity: 0.62;
}
