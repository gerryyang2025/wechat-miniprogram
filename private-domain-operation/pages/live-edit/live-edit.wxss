.live-edit-scroll {
  min-height: 100vh;
  padding: calc(108rpx + env(safe-area-inset-top)) 28rpx 48rpx;
  box-sizing: border-box;
}

.live-edit-nav {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding-bottom: 28rpx;
}

.live-edit-back {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  font-size: 44rpx;
  line-height: 72rpx;
  text-align: center;
}

.live-edit-nav-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.live-edit-nav-title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #ffffff;
}

.live-edit-nav-subtitle {
  font-size: 24rpx;
  color: rgba(241, 244, 255, 0.82);
}

.live-edit-placeholder {
  margin-top: 24rpx;
  padding: 34rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.live-edit-placeholder-title {
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #222946;
}

.live-edit-placeholder-desc {
  font-size: 26rpx;
  line-height: 1.7;
  color: #697394;
}

.live-edit-placeholder-id {
  align-self: flex-start;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(83, 112, 255, 0.1);
  color: #5b6dfc;
  font-size: 22rpx;
  font-weight: 700;
}
