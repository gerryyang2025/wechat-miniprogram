.live-room-scroll {
  min-height: 100vh;
  padding: calc(108rpx + env(safe-area-inset-top)) 28rpx 0;
  box-sizing: border-box;
}

.live-room-nav {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding-bottom: 28rpx;
}

.live-room-back {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  font-size: 44rpx;
  line-height: 72rpx;
  text-align: center;
}

.live-room-nav-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.live-room-nav-title {
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #ffffff;
}

.live-room-nav-subtitle {
  font-size: 24rpx;
  color: rgba(241, 244, 255, 0.82);
}

.live-room-stage {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.live-room-video {
  position: relative;
  height: 420rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(145deg, #29326a 0%, #4350d8 40%, #7f73ff 100%);
}

.live-room-status {
  position: absolute;
  top: 22rpx;
  right: 22rpx;
  height: 46rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.live-room-status--live {
  background: rgba(52, 171, 107, 0.92);
}

.live-room-status--replay {
  background: rgba(88, 112, 251, 0.92);
}

.live-room-center-copy {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.live-room-center-title {
  font-size: 34rpx;
  line-height: 1.4;
  color: #ffffff;
  font-weight: 800;
}

.live-room-center-topic {
  font-size: 24rpx;
  line-height: 1.65;
  color: rgba(244, 247, 255, 0.86);
}

.live-room-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.live-room-info-title {
  font-size: 30rpx;
  line-height: 1.4;
  color: #202742;
  font-weight: 800;
}

.live-room-info-subtitle,
.live-room-notice {
  font-size: 24rpx;
  line-height: 1.72;
  color: #66719a;
}

.live-room-section {
  margin-top: 24rpx;
  padding: 28rpx;
}

.live-room-section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
}

.live-room-section-title {
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #202742;
}

.live-room-section-note {
  font-size: 22rpx;
  color: #8d96b7;
}

.live-room-bullet-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.live-room-bullet-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.live-room-bullet-dot {
  flex-shrink: 0;
  width: 14rpx;
  height: 14rpx;
  margin-top: 10rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4d78ff 0%, #7a56ff 100%);
}

.live-room-bullet-text {
  font-size: 24rpx;
  line-height: 1.72;
  color: #66719a;
}

.message-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.message-item {
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(243, 246, 255, 0.96);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.message-user {
  font-size: 22rpx;
  color: #5d6cf8;
  font-weight: 700;
}

.message-text,
.related-desc {
  font-size: 24rpx;
  line-height: 1.7;
  color: #66719a;
}

.related-card {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #f0efff 0%, #ffffff 100%);
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.related-tag {
  align-self: flex-start;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(108, 124, 255, 0.1);
  color: #6278f4;
  font-size: 20rpx;
  font-weight: 700;
}

.related-title {
  font-size: 28rpx;
  line-height: 1.45;
  color: #202742;
  font-weight: 700;
}

.live-room-bottom-spacer {
  height: calc(148rpx + env(safe-area-inset-bottom));
}

.live-room-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(247, 249, 255, 0.92);
  backdrop-filter: blur(12px);
  box-shadow: 0 -18rpx 40rpx rgba(69, 82, 147, 0.08);
}

.live-room-footer-inner {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.live-room-input {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  padding: 0 28rpx;
  border-radius: 26rpx;
  background: rgba(239, 243, 255, 0.96);
  color: #98a2c2;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.live-room-action {
  flex-shrink: 0;
  min-width: 188rpx;
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, #4f80ff 0%, #7258ff 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
