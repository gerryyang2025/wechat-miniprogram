.rights-scroll {
  min-height: 100vh;
  padding: calc(108rpx + env(safe-area-inset-top)) 28rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.rights-nav {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding-bottom: 28rpx;
}

.rights-back {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  font-size: 44rpx;
  line-height: 72rpx;
  text-align: center;
}

.rights-nav-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.rights-nav-title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #ffffff;
}

.rights-nav-subtitle {
  font-size: 24rpx;
  color: rgba(241, 244, 255, 0.82);
}

.rights-hero,
.rights-section {
  margin-top: 24rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rights-badge {
  align-self: flex-start;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 171, 76, 0.16);
  color: #d98a2f;
  font-size: 22rpx;
  font-weight: 700;
}

.rights-title,
.rights-section-title {
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 800;
  color: #222946;
}

.rights-desc,
.rights-item-desc,
.rights-note-text {
  font-size: 24rpx;
  line-height: 1.72;
  color: #7f89ab;
}

.rights-list,
.rights-note-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.rights-item {
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(245, 248, 255, 0.92);
  border: 1rpx solid rgba(224, 230, 250, 0.94);
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.rights-item-title {
  font-size: 28rpx;
  line-height: 1.45;
  color: #202742;
  font-weight: 700;
}

.rights-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.rights-chip {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(239, 243, 255, 0.96);
  color: #57627f;
  font-size: 22rpx;
  font-weight: 600;
}

.rights-note-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.rights-note-dot {
  flex-shrink: 0;
  width: 14rpx;
  height: 14rpx;
  margin-top: 10rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4d78ff 0%, #7a56ff 100%);
}
