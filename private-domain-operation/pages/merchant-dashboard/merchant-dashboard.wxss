.merchant-scroll {
  min-height: 100vh;
  padding: calc(108rpx + env(safe-area-inset-top)) 28rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.merchant-nav {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding-bottom: 28rpx;
}

.merchant-back {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  font-size: 44rpx;
  line-height: 72rpx;
  text-align: center;
}

.merchant-nav-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.merchant-nav-title {
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #ffffff;
}

.merchant-nav-subtitle {
  font-size: 24rpx;
  color: rgba(241, 244, 255, 0.82);
}

.merchant-hero,
.merchant-section {
  margin-top: 24rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.merchant-badge {
  align-self: flex-start;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(83, 112, 255, 0.1);
  color: #5b6dfc;
  font-size: 22rpx;
  font-weight: 700;
}

.merchant-title,
.merchant-section-title {
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 800;
  color: #222946;
}

.merchant-desc,
.merchant-section-note,
.metric-note,
.todo-note,
.shortcut-hint,
.activity-time,
.activity-note {
  font-size: 24rpx;
  line-height: 1.72;
  color: #7f89ab;
}

.merchant-section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.metric-card {
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(245, 248, 255, 0.92);
  border: 1rpx solid rgba(224, 230, 250, 0.94);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.metric-value {
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #24315b;
}

.metric-label,
.todo-title,
.shortcut-title,
.activity-title {
  font-size: 28rpx;
  line-height: 1.45;
  color: #202742;
  font-weight: 700;
}

.todo-list,
.activity-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.todo-item,
.activity-item {
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(247, 249, 255, 0.9);
  border: 1rpx solid rgba(224, 230, 250, 0.94);
}

.todo-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.todo-tag {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(92, 108, 255, 0.1);
  color: #6172ff;
  font-size: 20rpx;
  font-weight: 700;
}

.todo-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.shortcut-item {
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, rgba(239, 244, 255, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.activity-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
