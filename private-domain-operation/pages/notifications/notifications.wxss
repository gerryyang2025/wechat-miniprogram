.notifications-scroll {
  min-height: 100vh;
  padding: calc(108rpx + env(safe-area-inset-top)) 28rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.notifications-nav {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding-bottom: 28rpx;
}

.notifications-back {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  font-size: 44rpx;
  line-height: 72rpx;
  text-align: center;
}

.notifications-nav-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.notifications-nav-title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #ffffff;
}

.notifications-nav-subtitle {
  font-size: 24rpx;
  color: rgba(241, 244, 255, 0.82);
}

.notifications-hero,
.notifications-section,
.notification-card {
  margin-top: 24rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.notifications-badge {
  align-self: flex-start;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(83, 112, 255, 0.1);
  color: #5b6dfc;
  font-size: 22rpx;
  font-weight: 700;
}

.notifications-title,
.notifications-section-title {
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 800;
  color: #222946;
}

.notifications-desc,
.notification-summary,
.notifications-tip-text {
  font-size: 24rpx;
  line-height: 1.72;
  color: #7f89ab;
}

.notifications-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.notification-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.notification-category {
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(239, 243, 255, 0.96);
  color: #6172ff;
  font-size: 20rpx;
  font-weight: 700;
}

.notification-time {
  font-size: 22rpx;
  color: #98a2c2;
}

.notification-title {
  font-size: 28rpx;
  line-height: 1.45;
  color: #202742;
  font-weight: 700;
}

.notifications-tip-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.notifications-tip-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.notifications-tip-dot {
  flex-shrink: 0;
  width: 14rpx;
  height: 14rpx;
  margin-top: 10rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4d78ff 0%, #7a56ff 100%);
}
