.detail-scroll {
  min-height: 100vh;
  padding: calc(108rpx + env(safe-area-inset-top)) 28rpx 0;
  box-sizing: border-box;
}

.detail-nav {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding-bottom: 28rpx;
}

.detail-back {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  font-size: 44rpx;
  line-height: 72rpx;
  text-align: center;
}

.detail-nav-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.detail-nav-title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #ffffff;
}

.detail-nav-subtitle {
  font-size: 24rpx;
  color: rgba(241, 244, 255, 0.82);
}

.detail-hero {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.detail-cover {
  height: 280rpx;
  border-radius: 28rpx;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: #ffffff;
}

.cover-purple {
  background: linear-gradient(145deg, #6f57ff 0%, #4f90ff 100%);
}

.cover-blue {
  background: linear-gradient(145deg, #2b80ff 0%, #56c7ff 100%);
}

.cover-indigo {
  background: linear-gradient(145deg, #4250d8 0%, #7f73ff 100%);
}

.detail-cover-tag {
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
  font-weight: 700;
}

.detail-cover-hint {
  width: 70%;
  font-size: 34rpx;
  line-height: 1.45;
  font-weight: 700;
}

.detail-main {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.detail-title {
  font-size: 40rpx;
  line-height: 1.35;
  color: #202742;
  font-weight: 800;
}

.detail-author,
.detail-meta {
  font-size: 24rpx;
  color: #818aac;
}

.detail-price-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding-top: 6rpx;
}

.detail-price {
  font-size: 38rpx;
  font-weight: 800;
  color: #5b6dfc;
}

.detail-access {
  font-size: 22rpx;
  color: #66719a;
}

.detail-description {
  font-size: 26rpx;
  line-height: 1.72;
  color: #606a8f;
}

.detail-section,
.detail-note {
  margin-top: 24rpx;
  padding: 28rpx;
}

.detail-section-title {
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #202742;
}

.detail-section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
}

.detail-section-note {
  font-size: 22rpx;
  color: #8d96b7;
}

.detail-progress-row {
  margin-top: 20rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
}

.detail-progress-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.detail-progress-value {
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #23315c;
}

.detail-progress-meta,
.detail-progress-line,
.chapter-summary,
.outline-duration {
  font-size: 22rpx;
  line-height: 1.6;
  color: #7f89ab;
}

.detail-progress-percent {
  flex-shrink: 0;
  font-size: 30rpx;
  font-weight: 800;
  color: #5b6dfc;
}

.detail-progress-bar {
  width: 100%;
  height: 18rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  background: rgba(234, 239, 255, 0.96);
  overflow: hidden;
}

.detail-progress-inner {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(135deg, #6172ff 0%, #5ac3ff 100%);
}

.detail-progress-note {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.detail-bottom-spacer {
  height: calc(148rpx + env(safe-area-inset-bottom));
}

.bullet-list,
.outline-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.bullet-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.bullet-dot {
  flex-shrink: 0;
  width: 14rpx;
  height: 14rpx;
  margin-top: 10rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4d78ff 0%, #7a56ff 100%);
}

.bullet-text,
.outline-text,
.detail-note-text {
  font-size: 24rpx;
  line-height: 1.72;
  color: #66719a;
}

.tag-row {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(238, 242, 255, 0.96);
  color: #57627f;
  font-size: 22rpx;
  font-weight: 600;
}

.chapter-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.chapter-item {
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(247, 249, 255, 0.88);
  border: 1rpx solid rgba(223, 229, 252, 0.92);
}

.chapter-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.chapter-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.chapter-title {
  font-size: 26rpx;
  line-height: 1.5;
  font-weight: 700;
  color: #263255;
}

.chapter-count {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(92, 108, 255, 0.1);
  color: #6172ff;
  font-size: 20rpx;
  font-weight: 700;
}

.outline-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.outline-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.detail-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(247, 249, 255, 0.92);
  backdrop-filter: blur(12px);
  box-shadow: 0 -18rpx 40rpx rgba(69, 82, 147, 0.08);
}

.detail-footer-inner {
  display: flex;
  gap: 16rpx;
}

.detail-secondary,
.detail-primary {
  height: 88rpx;
  border-radius: 28rpx;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-secondary {
  flex: 1;
  background: rgba(92, 108, 255, 0.08);
  color: #5a6efa;
}

.detail-primary {
  flex: 1.2;
  background: linear-gradient(135deg, #4f80ff 0%, #7258ff 100%);
  color: #ffffff;
}

.outline-state {
  flex-shrink: 0;
  margin-top: 4rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.outline-state--completed {
  background: rgba(68, 125, 255, 0.12);
  color: #4f6dff;
}

.outline-state--current {
  background: rgba(103, 93, 255, 0.14);
  color: #675dff;
}

.outline-state--preview {
  background: rgba(61, 188, 150, 0.14);
  color: #2da17f;
}

.outline-state--upcoming,
.outline-state--locked {
  background: rgba(228, 233, 249, 0.94);
  color: #8d96b7;
}
