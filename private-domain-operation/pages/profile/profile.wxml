<view class="page-shell">
  <scroll-view scroll-y class="profile-scroll content-safe-bottom">
    <view class="profile-head">
      <view class="profile-card card-surface">
        <view class="avatar-circle">{{profileCard.avatarText}}</view>
        <view class="profile-copy">
          <text class="profile-name">{{profileCard.name}}</text>
          <text class="profile-meta">{{profileCard.meta}}</text>
          <text class="profile-badge">{{profileCard.badge}}</text>
        </view>
      </view>
    </view>

    <view class="member-card card-surface">
      <text class="member-title">{{memberCard.title}}</text>
      <text class="member-desc">{{memberCard.desc}}</text>
      <view class="ghost-button" data-label="{{memberCard.actionTarget}}" bindtap="onFeatureTap">{{memberCard.actionLabel}}</view>
    </view>

    <view class="merchant-entry card-surface" data-label="{{merchantEntry.actionTarget}}" bindtap="onFeatureTap">
      <view class="merchant-entry-copy">
        <text class="merchant-entry-title">{{merchantEntry.title}}</text>
        <text class="merchant-entry-desc">{{merchantEntry.desc}}</text>
      </view>
      <text class="merchant-entry-action">{{merchantEntry.actionLabel}}</text>
    </view>

    <view class="service-list card-surface">
      <view
        wx:for="{{serviceItems}}"
        wx:key="label"
        class="service-item"
        data-label="{{item.label}}"
        bindtap="onFeatureTap"
      >
        <text class="service-label">{{item.label}}</text>
        <text class="service-arrow">›</text>
      </view>
    </view>

    <view class="profile-bottom-spacer"></view>
  </scroll-view>

  <bottom-nav current="profile"></bottom-nav>
</view>
