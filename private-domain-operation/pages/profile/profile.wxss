.profile-scroll {
  min-height: 100vh;
  padding: calc(108rpx + env(safe-area-inset-top)) 28rpx 0;
  box-sizing: border-box;
}

.profile-head {
  padding-bottom: 28rpx;
}

.profile-card {
  padding: 30rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-circle {
  flex-shrink: 0;
  width: 112rpx;
  height: 112rpx;
  border-radius: 999rpx;
  background: linear-gradient(145deg, #5c8cff 0%, #715bff 100%);
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #232946;
}

.profile-meta {
  font-size: 24rpx;
  color: #8089ad;
}

.profile-badge {
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 171, 76, 0.14);
  color: #e28b2d;
  font-size: 22rpx;
  font-weight: 700;
}

.member-card {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  background: linear-gradient(145deg, rgba(239, 244, 255, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
}

.merchant-entry {
  margin-top: 26rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.merchant-entry-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.merchant-entry-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #222846;
}

.merchant-entry-desc {
  font-size: 24rpx;
  line-height: 1.65;
  color: #818aad;
}

.merchant-entry-action {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(92, 108, 255, 0.08);
  color: #5a6efa;
  font-size: 22rpx;
  font-weight: 700;
}

.member-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #222846;
}

.member-desc {
  font-size: 24rpx;
  line-height: 1.65;
  color: #818aad;
}

.service-list {
  margin-top: 26rpx;
  padding: 8rpx 30rpx;
}

.service-item {
  height: 108rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(126, 138, 184, 0.14);
}

.service-item:last-child {
  border-bottom: none;
}

.service-label {
  font-size: 30rpx;
  color: #232846;
  font-weight: 600;
}

.service-arrow {
  font-size: 40rpx;
  color: #b0b7d1;
}

.profile-bottom-spacer {
  height: calc(148rpx + env(safe-area-inset-bottom));
}
