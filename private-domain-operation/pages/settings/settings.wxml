<view class="page-shell">
  <scroll-view scroll-y class="settings-scroll">
    <view class="settings-nav">
      <view class="settings-back" bindtap="onBackTap">‹</view>
      <view class="settings-nav-copy">
        <text class="settings-nav-title">系统设置</text>
        <text class="settings-nav-subtitle">{{navSubtitle}}</text>
      </view>
    </view>

    <view class="settings-hero card-surface">
      <text class="settings-badge">{{heroBadge}}</text>
      <text class="settings-title">{{heroTitle}}</text>
      <text class="settings-desc">{{heroDesc}}</text>
    </view>

    <view class="settings-section card-surface">
      <text class="settings-section-title">开关设置</text>
      <view wx:for="{{switchItems}}" wx:key="key" class="settings-switch-item">
        <view class="settings-switch-copy">
          <text class="settings-switch-title">{{item.title}}</text>
          <text class="settings-switch-desc">{{item.desc}}</text>
        </view>
        <switch color="#6172ff" checked="{{switches[item.key]}}" data-key="{{item.key}}" bindchange="onSwitchChange"></switch>
      </view>
    </view>

    <view class="settings-section card-surface">
      <text class="settings-section-title">账户信息</text>
      <view class="settings-note-list">
        <view wx:for="{{accountInfo}}" wx:key="*this" class="settings-note-item">
          <text class="settings-note-dot"></text>
          <text class="settings-note-text">{{item}}</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
