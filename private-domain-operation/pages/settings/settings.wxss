.settings-scroll {
  min-height: 100vh;
  padding: calc(108rpx + env(safe-area-inset-top)) 28rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.settings-nav {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding-bottom: 28rpx;
}

.settings-back {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  font-size: 44rpx;
  line-height: 72rpx;
  text-align: center;
}

.settings-nav-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.settings-nav-title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #ffffff;
}

.settings-nav-subtitle {
  font-size: 24rpx;
  color: rgba(241, 244, 255, 0.82);
}

.settings-hero,
.settings-section {
  margin-top: 24rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.settings-badge {
  align-self: flex-start;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(83, 112, 255, 0.1);
  color: #5b6dfc;
  font-size: 22rpx;
  font-weight: 700;
}

.settings-title,
.settings-section-title {
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 800;
  color: #222946;
}

.settings-desc,
.settings-switch-desc,
.settings-note-text {
  font-size: 24rpx;
  line-height: 1.72;
  color: #7f89ab;
}

.settings-switch-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(126, 138, 184, 0.14);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.settings-switch-item:last-child {
  border-bottom: none;
}

.settings-switch-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.settings-switch-title {
  font-size: 28rpx;
  line-height: 1.45;
  color: #202742;
  font-weight: 700;
}

.settings-note-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.settings-note-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.settings-note-dot {
  flex-shrink: 0;
  width: 14rpx;
  height: 14rpx;
  margin-top: 10rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4d78ff 0%, #7a56ff 100%);
}
