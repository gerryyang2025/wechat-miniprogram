.user-management-scroll {
  min-height: 100vh;
  padding: calc(108rpx + env(safe-area-inset-top)) 28rpx 0;
  box-sizing: border-box;
}

.user-management-nav {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding-bottom: 28rpx;
}

.user-management-back {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  font-size: 44rpx;
  line-height: 72rpx;
  text-align: center;
}

.user-management-nav-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-management-nav-title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #ffffff;
}

.user-management-nav-subtitle {
  font-size: 24rpx;
  color: rgba(241, 244, 255, 0.82);
}

.user-management-hero,
.user-management-filter,
.user-search {
  margin-top: 24rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.user-management-badge {
  align-self: flex-start;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(83, 112, 255, 0.1);
  color: #5b6dfc;
  font-size: 22rpx;
  font-weight: 700;
}

.user-management-title {
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 800;
  color: #222946;
}

.user-management-desc,
.user-phone,
.user-active,
.user-progress {
  font-size: 24rpx;
  line-height: 1.72;
  color: #7f89ab;
}

.user-search {
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.user-search-text {
  color: #9ca4c4;
  font-size: 28rpx;
}

.user-search-icon {
  font-size: 40rpx;
  color: #454d76;
}

.filter-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.filter-chip {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(239, 243, 255, 0.96);
  color: #7380a6;
  font-size: 24rpx;
  font-weight: 600;
}

.filter-chip--active {
  background: linear-gradient(135deg, #4f80ff 0%, #7258ff 100%);
  color: #ffffff;
}

.user-management-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.user-card {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.user-card-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.user-avatar {
  flex-shrink: 0;
  width: 88rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(145deg, #5c8cff 0%, #715bff 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.user-name {
  font-size: 30rpx;
  line-height: 1.45;
  color: #202742;
  font-weight: 800;
}

.user-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.user-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(239, 243, 255, 0.96);
  color: #6172ff;
  font-size: 20rpx;
  font-weight: 700;
}

.user-management-bottom-spacer {
  height: calc(48rpx + env(safe-area-inset-bottom));
}
