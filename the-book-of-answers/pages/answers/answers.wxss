@import "../../styles/result_actions.wxss";
@import "../../styles/result_panels.wxss";

page{
  background: #86061d;
}

/* answers.wxss */
.background{
  width: 100%;
  height: 100%;
  z-index: -1;
  position: fixed;
}

.modeSwitch{
  position: fixed;
  top: 24rpx;
  left: 24rpx;
  display: flex;
  align-items: center;
  z-index: 5;
  padding: 14rpx 26rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(255, 247, 249, 0.26), rgba(255, 218, 228, 0.1));
  border: 1px solid rgba(255, 245, 247, 0.4);
  backdrop-filter: blur(18rpx);
  box-shadow: 0 18rpx 34rpx rgba(80, 22, 43, 0.16), inset 0 1rpx 0 rgba(255, 255, 255, 0.34);
}

.modeSwitchText{
  color: #fff8f4;
  font-size: 24rpx;
  letter-spacing: 2rpx;
  line-height: 1.2;
  text-shadow: 0 4rpx 10rpx rgba(73, 14, 35, 0.16);
}

.backgroundImg{
  width: 100%;
  height: 100%;
  overflow: visible;
}

.content{
  width: 100%;
  margin: auto;
  color: white;
  align-items: center;
  position: fixed;
  text-align: center;
  padding: 0 72rpx;
  box-sizing: border-box;
  font-size: 32px;
  line-height: 1.45;
  top: 250rpx;
}

.subContent{
  width: 100%;
  margin: auto;
  color: white;
  position: fixed;
  text-align: center;
  padding: 0 96rpx;
  box-sizing: border-box;
  font-size: 14px;
  line-height: 1.7;
  top: 420rpx;

}

.contentBg{
  width: 700rpx;
  height: 432rpx;
  margin: auto;
  border-radius: 32rpx;
  background: #C4000C;
  position: fixed;
  left: 25rpx;
  top: 160rpx;
  /*box-shadow:2px 2px 3px #000000; */
  /*opacity: 1;*/
}

.exp{
  width: 100%;
  margin: auto;
  color: white;
  position: fixed;
  text-align: center;
  padding: 0 96rpx;
  box-sizing: border-box;
  font-size: 18px;
  line-height: 1.6;
  bottom: 420rpx;
}

.table{
  width: 100%;
  margin: auto;
  display: flex;
  flex-direction: column;
  position: fixed;
  align-items: center;
  bottom: 80rpx;
}

.tableImg{
  width: 256rpx;
  height: 256rpx;
  margin: auto;
}

.tableHint{
  margin-top: 20rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 24rpx;
  line-height: 1.5;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.24);
}

.shareCanvas{
  width: 600px;
  height: 600px;
  position: fixed;
  left: -9999px;
  top: 0;
  pointer-events: none;
  z-index: -10;
}
