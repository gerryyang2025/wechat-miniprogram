}

.content1{
  width: 100%;
  z-index: -1;
  margin: auto;
  align-items: center;
  position: fixed;
  text-align: center;
  padding: 0 60rpx;
  box-sizing: border-box;
  font-size: 56rpx;
  line-height: 1.45;
  top: 305rpx;
}

.content2{
  width: 100%;
  margin: auto;
  z-index: -1;
  position: fixed;
  text-align: center;
  padding: 0 88rpx;
  box-sizing: border-box;
  font-size: 27rpx;
  line-height: 1.6;
  top: 537rpx;
}

.exp{
  z-index: -1;
  position: fixed;
  min-height: 100rpx;
  right: 105rpx;/*让对话框靠右，自适应的时候宽度向左扩张*/
  bottom: 180rpx;
  pointer-events: none;
  opacity: 0;
  transition: opacity 1s;
  -webkit-transition: opacity 1s;
}

.exp-show{
  opacity: 1;
  transition: opacity 1s;
  -webkit-transition: opacity 1s;
}

.c-dialog{
  display: flex;
  top: 0;
  min-height: 64rpx;
  min-width: 200rpx;
  max-width: 100%;
  color: #E20B4F;
  background: rgba(255,255,255,.6);
  border-radius: 10rpx;
  padding: 0 20rpx;
  justify-content: center;
  box-shadow: 0 0 20rpx 0 rgba(0,0,0,.2);
}
.c-dialog:after{
  content: "";
  position: absolute;
  top: 64rpx;
  right: 130rpx;
  width: 0;
  height: 0;
  border-top: 20rpx solid rgba(255,255,255,.6);
  border-right: 20rpx solid transparent;
}

#exp-txt{
  padding: 10rpx 20rpx;
  margin: auto;
  vertical-align: middle;
  font-size: 27rpx;
  color: #9f1b55;
  opacity: 1;
}

.tutorial{
  width: 100%;
  height: auto;
  z-index: -1;
  margin: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  position: fixed;
  top: 202rpx;
  pointer-events: none;
}

.tutorial-txt1{
  width: 100%;
  margin: auto;
  text-align: center;
  font-size: 40rpx;
}

.tutorial-txt2{
  width: 100%;
  margin-top: 80rpx;
  text-align: center;
  font-size: 28rpx;
  line-height: 60rpx;
}

.tutorial-txt3{
  width: 100%;
  margin-top: 80rpx;
  text-align: center;
  font-size: 40rpx;
}

.circle-container{
  width: 100%;
  height: auto;
  display: flex;
  position: fixed;
  align-items: center;
  bottom: 120rpx;
}

.circle{
  width: 80rpx;
  height: 80rpx;
  margin: auto;
  border: 10rpx solid rgba(255,255,255,0.7);
  border-radius: 50%;
  box-shadow: 0 0 20rpx 0 rgba(0,0,0,.2);
}

.circle-line-container{
  width: 100%;
  height: auto;
  display: flex;
  position: fixed;
  align-items: center;
  bottom: 110rpx;
}

.circle-line{
  width: 114rpx;
  height: 114rpx;
  margin: auto;
  border: 4rpx solid white;
  border-radius: 50%;
  box-shadow: 0 0 20rpx 0 rgba(0,0,0,.2);
}

.canvas-big{
  width: 750px;
  height: 1334px;
  position: fixed;
  left: -9999px;
  top: 0;
  pointer-events: none;
  z-index: -10; 
}

.share-canvas{
  width: 600px;
  height: 600px;
  position: fixed;
  left: -9999px;
  top: 0;
  pointer-events: none;
  z-index: -10;
}

.poster-error-mask{
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 12;
  background: rgba(22, 10, 26, 0.66);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 28rpx;
  box-sizing: border-box;
}

.poster-error-card{
  width: 100%;
  max-width: 640rpx;
  padding: 40rpx 32rpx 36rpx;
  border-radius: 32rpx;
  background: rgba(255,255,255,.94);
  box-sizing: border-box;
  box-shadow: 0 24rpx 48rpx rgba(0,0,0,.18);
}

.poster-error-title{
  display: block;
  color: #92385d;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.4;
}

.poster-error-message{
  display: block;
  margin-top: 16rpx;
  color: rgba(99, 34, 63, 0.88);
  font-size: 26rpx;
  line-height: 1.7;
}

.poster-error-support{
  display: block;
  margin-top: 14rpx;
  color: rgba(99, 34, 63, 0.64);
  font-size: 22rpx;
  line-height: 1.7;
}

.poster-error-link{
  display: inline-block;
  margin-top: 18rpx;
  color: #b04c67;
  font-size: 24rpx;
  line-height: 1.5;
}

.poster-error-actions{
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.poster-error-btn{
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 84rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.poster-error-btn-primary{
  background: linear-gradient(135deg, #f49f62, #d75862);
}

.poster-error-btn-secondary{
  background: rgba(146, 56, 93, 0.08);
  border: 1px solid rgba(146, 56, 93, 0.14);
}

.poster-error-btn-txt{
  color: white;
  font-size: 26rpx;
  font-weight: 600;
}

.poster-error-btn-txt-secondary{
  color: #92385d;
}

.thanks{
  width: 100%;
  z-index: -1;
  position: fixed;
  bottom: 10rpx;
  text-align: right;
}

.thanks-txt{
  color: #9D3170;
  margin-right: 16rpx;
  font-size: 16rpx;
  text-shadow: 2rpx 2rpx rgba(0,0,0,.4);
}
