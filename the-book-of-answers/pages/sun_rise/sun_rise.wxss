  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.4;
}

.poster-error-message{
  display: block;
  margin-top: 16rpx;
  color: rgba(99, 34, 63, 0.88);
  font-size: 26rpx;
  line-height: 1.7;
}

.poster-error-support{
  display: block;
  margin-top: 14rpx;
  color: rgba(99, 34, 63, 0.64);
  font-size: 22rpx;
  line-height: 1.7;
}

.poster-error-link{
  display: inline-block;
  margin-top: 18rpx;
  color: #b04c67;
  font-size: 24rpx;
  line-height: 1.5;
}

.poster-error-actions{
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.poster-error-btn{
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 84rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.poster-error-btn-primary{
  background: linear-gradient(135deg, #f49f62, #d75862);
}

.poster-error-btn-secondary{
  background: rgba(146, 56, 93, 0.08);
  border: 1px solid rgba(146, 56, 93, 0.14);
}

.poster-error-btn-txt{
  color: white;
  font-size: 26rpx;
  font-weight: 600;
}

.poster-error-btn-txt-secondary{
  color: #92385d;
}

.thanks{
  width: 100%;
  z-index: -1;
  position: fixed;
  bottom: 10rpx;
  text-align: right;
}

.thanks-txt{
  color: #9D3170;
  margin-right: 16rpx;
  font-size: 16rpx;
  text-shadow: 2rpx 2rpx rgba(0,0,0,.4);
}

@keyframes repeatHintBreathe{
  0%, 100%{
    opacity: 0.36;
    transform: translate(-50%, -50%) scale(0.88);
  }
  50%{
    opacity: 0.92;
    transform: translate(-50%, -50%) scale(1.18);
  }
}

@keyframes repeatHintDotGlow{
  0%, 100%{
    opacity: 0.72;
    transform: translate(-50%, -50%) scale(0.92);
  }
  50%{
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.14);
  }
}

@keyframes repeatHintGuideGlow{
  0%, 100%{
    opacity: 0.38;
    transform: scaleX(0.88);
  }
  50%{
    opacity: 0.72;
    transform: scaleX(1);
  }
}

@keyframes pressCueFill{
  from{
    transform: scaleX(0);
  }
  to{
    transform: scaleX(1);
  }
}

@keyframes tutorialCoreBreathe{
  0%, 100%{
    box-shadow: 0 0 20rpx rgba(255,255,255,.12), 0 0 20rpx rgba(0,0,0,.16);
    border-color: rgba(255,255,255,.68);
  }
  50%{
    box-shadow: 0 0 34rpx rgba(255,255,255,.36), 0 0 26rpx rgba(255, 215, 185, .24);
    border-color: rgba(255,255,255,.9);
  }
}

@keyframes tutorialHaloBreathe{
  0%, 100%{
    box-shadow: 0 0 22rpx rgba(255,255,255,.1), 0 0 16rpx rgba(0,0,0,.14);
    border-color: rgba(255,255,255,.62);
  }
  50%{
    box-shadow: 0 0 38rpx rgba(255,255,255,.24), 0 0 26rpx rgba(255, 212, 176, .18);
    border-color: rgba(255,255,255,.86);
  }
}
