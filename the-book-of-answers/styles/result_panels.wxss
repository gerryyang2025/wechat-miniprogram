.result-overlay{
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.result-overlay--record{
  z-index: 10;
  background: rgba(16, 9, 30, 0.6);
}

.result-overlay--detail{
  z-index: 11;
  background: rgba(22, 10, 26, 0.66);
}

.result-sheet{
  width: 100%;
  box-sizing: border-box;
  border-radius: 36rpx 36rpx 0 0;
}

.result-sheet--record{
  max-height: 70vh;
  padding: 36rpx 32rpx 48rpx;
}

.result-sheet--detail{
  max-height: 76vh;
  padding: 36rpx 32rpx 40rpx;
}

.result-theme--answers.result-sheet--record{
  background: linear-gradient(180deg, rgba(111, 9, 28, 0.98), rgba(58, 8, 23, 0.96));
}

.result-theme--sunrise.result-sheet--record{
  background: linear-gradient(180deg, rgba(250, 145, 101, 0.97), rgba(136, 37, 90, 0.98));
}

.result-theme--answers.result-sheet--detail{
  background: linear-gradient(180deg, rgba(255, 245, 244, 0.98), rgba(251, 228, 229, 0.98));
}

.result-theme--sunrise.result-sheet--detail{
  background: linear-gradient(180deg, rgba(255, 250, 244, 0.98), rgba(255, 238, 230, 0.98));
}

.result-sheet-header{
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.result-sheet-header--detail{
  align-items: flex-start;
  gap: 24rpx;
}

.result-sheet-title{
  color: white;
  font-size: 34rpx;
  font-weight: 600;
}

.result-sheet-close{
  font-size: 24rpx;
}

.result-sheet--record .result-sheet-close{
  color: rgba(255, 255, 255, 0.82);
}

.result-theme--answers .result-sheet-close{
  color: rgba(125, 17, 44, 0.7);
}

.result-theme--sunrise .result-sheet-close{
  color: rgba(143, 55, 93, 0.72);
}

.result-sheet-empty{
  padding: 48rpx 24rpx 64rpx;
  text-align: center;
}

.result-sheet-empty-text{
  color: rgba(255, 255, 255, 0.8);
  font-size: 26rpx;
  line-height: 1.7;
}

.result-sheet-list{
  max-height: 58vh;
}

.result-sheet-item{
  padding: 24rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.12);
}

.result-sheet-item-content{
  display: block;
  color: white;
  font-size: 34rpx;
  line-height: 1.45;
}

.result-sheet-item-sub{
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
  line-height: 1.5;
}

.result-sheet-item-exp{
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  line-height: 1.5;
}

.result-sheet-item-meta{
  display: block;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.56);
  font-size: 22rpx;
}

.result-sheet-heading{
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.result-sheet-eyebrow{
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.result-theme--answers .result-sheet-eyebrow{
  color: rgba(154, 23, 48, 0.72);
}

.result-theme--sunrise .result-sheet-eyebrow{
  color: rgba(173, 82, 96, 0.74);
}

.result-sheet-detail-title{
  font-size: 36rpx;
  line-height: 1.4;
  font-weight: 600;
}

.result-theme--answers .result-sheet-detail-title{
  color: #7d112c;
}

.result-theme--sunrise .result-sheet-detail-title{
  color: #8f375d;
}

.result-sheet-body{
  max-height: 60vh;
  margin-top: 28rpx;
}

.result-sheet-section{
  padding: 22rpx 0;
}

.result-theme--answers .result-sheet-section{
  border-bottom: 1px solid rgba(125, 17, 44, 0.08);
}

.result-theme--sunrise .result-sheet-section{
  border-bottom: 1px solid rgba(143, 55, 93, 0.08);
}

.result-sheet-section-label{
  display: block;
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.result-theme--answers .result-sheet-section-label{
  color: rgba(154, 23, 48, 0.78);
}

.result-theme--sunrise .result-sheet-section-label{
  color: rgba(173, 82, 96, 0.82);
}

.result-sheet-section-text{
  display: block;
  margin-top: 10rpx;
  font-size: 28rpx;
  line-height: 1.8;
}

.result-theme--answers .result-sheet-section-text{
  color: #5f0d24;
}

.result-theme--sunrise .result-sheet-section-text{
  color: #6d2948;
}
